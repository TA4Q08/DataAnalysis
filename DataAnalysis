import re
import csv
from datetime import datetime
from collections import defaultdict

INPUT_FILE = "LOGDATENTESTTESTTEST.txt"
OUTPUT_FILE = "chat_analysis_per_page.csv"


def count_words(text):
    if not text:
        return 0
    return len(re.findall(r"\b\w+\b", text))


def parse_log(filepath):

    entries = []
    current = {}
    content_lines = []
    collecting_content = False

    with open(filepath, encoding="utf-8") as f:

        for line in f:
            line = line.rstrip()

            if line.startswith("TYPE:"):
                if current:
                    if content_lines:
                        current["CONTENT"] = " ".join(content_lines)
                    entries.append(current)

                current = {"TYPE": line.split(": ",1)[1]}
                content_lines = []
                collecting_content = False

            elif line.startswith("TIME:"):
                time_str = line.split(": ",1)[1]
                current["TIME"] = datetime.fromisoformat(time_str.replace("Z","+00:00"))

            elif line.startswith("URL:"):
                current["URL"] = line.split(": ",1)[1]

            elif line.startswith("CONTENT:"):
                collecting_content = True
                content_lines = [line.split(": ",1)[1]]

            elif collecting_content and not re.match(r"^[A-Z_]+:", line):
                content_lines.append(line)

        if current:
            if content_lines:
                current["CONTENT"] = " ".join(content_lines)
            entries.append(current)

    return entries


def analyze(entries):

    stats = defaultdict(lambda: {
        "user_messages":0,
        "assistant_messages":0,
        "user_words":0,
        "assistant_words":0,
        "times":[]
    })

    for e in entries:

        url = e.get("URL","UNKNOWN")
        typ = e.get("TYPE","")
        content = e.get("CONTENT","")
        time = e.get("TIME")

        if time:
            stats[url]["times"].append(time)

        words = count_words(content)

        if typ == "USER_MESSAGE":
            stats[url]["user_messages"] += 1
            stats[url]["user_words"] += words

        elif typ == "ASSISTANT_MESSAGE":
            stats[url]["assistant_messages"] += 1
            stats[url]["assistant_words"] += words

    rows = []

    total_user_messages = 0
    total_assistant_messages = 0
    total_user_words = 0
    total_assistant_words = 0
    total_turns = 0
    total_duration = 0

    for url,data in stats.items():

        if data["times"]:
            duration = (max(data["times"]) - min(data["times"])).total_seconds()
        else:
            duration = 0

        turns = min(data["user_messages"], data["assistant_messages"])

        rows.append([
            url,
            data["user_messages"],
            data["assistant_messages"],
            turns,
            data["user_words"],
            data["assistant_words"],
            round(duration,2)
        ])

        total_user_messages += data["user_messages"]
        total_assistant_messages += data["assistant_messages"]
        total_user_words += data["user_words"]
        total_assistant_words += data["assistant_words"]
        total_turns += turns
        total_duration += duration

    rows.append([
        "TOTAL",
        total_user_messages,
        total_assistant_messages,
        total_turns,
        total_user_words,
        total_assistant_words,
        round(total_duration,2)
    ])

    return rows


def write_csv(rows):

    with open(OUTPUT_FILE,"w",newline="",encoding="utf-8") as f:

        writer = csv.writer(f)

        writer.writerow([
            "URL",
            "User_Messages",
            "Assistant_Messages",
            "Turns",
            "User_Words",
            "Assistant_Words",
            "Duration_Seconds"
        ])

        writer.writerows(rows)


entries = parse_log(INPUT_FILE)
rows = analyze(entries)
write_csv(rows)

print("Fertig. CSV erstellt:", OUTPUT_FILE)
